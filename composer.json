{
	"name": "laravel/laravel",
	"type": "project",
	"description": "The Laravel Framework.",
	"keywords": [
		"framework",
		"laravel"
	],
	"license": "MIT",

	"require": {
		"php": "^8.0.2",
		"barryvdh/laravel-dompdf": "^2.0",
		"codegreencreative/laravel-samlidp": "5.2.11",
		"directorytree/ldaprecord-laravel": "^2.6",
		"doctrine/dbal": "^3.4",
		"dompdf/dompdf": "^2.0",
		"ebess/advanced-nova-media-library": "^4.2",
		"fruitcake/laravel-cors": "^3.0",
		"guzzlehttp/guzzle": "^7.2",
		"laravel/dusk": "^7.7",
		"laravel/framework": "^9.19",
		"laravel/nova": "~4.34.3",
		"laravel/sanctum": "^3.0",
		"laravel/scout": "^10.8",
		"laravel/tinker": "^2.7",
		"laravel/ui": "^4.2.0",
		"livewire/livewire": "^2.11",
		"maatwebsite/excel": "^3.1",
		"maatwebsite/laravel-nova-excel": "^1.3",
		"mastani/nova-password-reset": "^1.2",
		"psr/simple-cache": "^2.0",
		"rap2hpoutre/fast-excel": "^3.0",
		"simonhamp/laravel-nova-csv-import": "^0.6.4",
		"symfony/mailgun-mailer": "^6.0",
		"uabookstores/laravel-shibboleth": "^3.4"
	},
	"require-dev": {
		"fakerphp/faker": "^1.9.1",
		"laravel/pint": "^1.0",
		"laravel/sail": "^1.0.1",
		"mockery/mockery": "^1.4.4",
		"nunomaduro/collision": "^6.1",
		"phpunit/phpunit": "^9.5.10",
		"spatie/laravel-ignition": "^1.0"
	},
	"autoload": {
		"psr-4": {
			"App\\Nova\\": "app/Nova/",
			"App\\": "app/",
			"Database\\Factories\\": "database/factories/",
			"Database\\Seeders\\": "database/seeders/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"scripts": {
		"post-autoload-dump": [
			"Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
			"@php artisan package:discover --ansi"
		],
		"post-update-cmd": [
			"@php artisan vendor:publish --tag=laravel-assets --ansi --force"
		],
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
		],
		"post-create-project-cmd": [
			"@php artisan key:generate --ansi"
		]
	},
	"extra": {
		"laravel": {
			"dont-discover": []
		}
	},
	"config": {
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"sort-packages": true,
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"repositories": {
		"nova": {
			"type": "composer",
			"url": "https://nova.laravel.com"
		},
		"mostviewednotes": {
			"type": "path",
			"url": "nova-components/mostviewednotes"
		},
        "0": {
                    "type": "path",
                    "url": "./nova-components/mostviewednotes"
                },
                "1": {
                    "type": "path",
                    "url": "./nova-components/mostviewednotes"
                },
                "2": {
                    "type": "path",
                    "url": "./nova-components/mostviewednotes"
                },
                "3": {
                    "type": "path",
                    "url": "./nova-components/mostviewednotes"
                },
                "4": {
                    "type": "path",
                    "url": "./nova-components/mostviewednotes"
                }
	}
}
